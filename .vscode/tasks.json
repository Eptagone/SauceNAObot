{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C#: Watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/App"
      ],
      "options": {
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "base": "$msCompile",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building",
          "endsPattern": "Build succeeded"
        }
      }
    },
    {
      "label": "C#: Build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/App"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
